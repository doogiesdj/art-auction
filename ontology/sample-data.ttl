# 모네
aw:water-lilies-1906 a artwork:Artwork ;
    rdfs:label             "수련 1906"@ko , "Water Lilies 1906"@en ;
    artwork:createdBy      ar:monet-claude ;
    artwork:createdIn      pr:1900s ;
    artwork:belongsToMovement mv:impressionism ;
    artwork:hasColorPalette cp:warm-high-high ;
    artwork:medium         "oil on canvas" ;
    artwork:width          89.5 ;
    artwork:height         92.1 ;
    artwork:yearCreated    1906 .

aw:water-lilies-1922 a artwork:Artwork ;
    rdfs:label             "수련 1922"@ko , "Water Lilies 1922"@en ;
