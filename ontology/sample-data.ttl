# 출처 체인 (Provenance Chain)
# ─────────────────────────────────────────────

# 김환기 '어디서 무엇이 되어 다시 만나랴' 출처 체인
prov:where-p1 a provenance:ProvenanceRecord ;
    rdfs:label                "어디서 P1 — 김환기 작가 소유"@ko ;
    provenance:owner          "김환기" ;
    provenance:acquisitionDate "1970-01-01"^^xsd:date ;
