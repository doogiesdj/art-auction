    artwork:hasColorPalette cp:warm-high-high ;
    artwork:medium         "oil on canvas" ;
    artwork:width          200.0 ;
    artwork:height         180.0 ;
    artwork:yearCreated    1922 .

aw:haystacks-1891 a artwork:Artwork ;
