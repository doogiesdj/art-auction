# 미술품 경매 플랫폼 — 샘플 인스턴스 데이터
# 작가 5명, 작품 12점, 경매 로트 13개, 출처 체인 2개
# GraphRAG 테스트 시나리오: "1920년대 따뜻한 색조 인상주의 낙찰가 1억 이상" → aw:water-lilies-1922

@prefix owl:        <http://www.w3.org/2002/07/owl#> .
@prefix rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:       <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .
@prefix artwork:    <http://art-auction.io/ontology/artwork#> .
@prefix auction:    <http://art-auction.io/ontology/auction#> .
@prefix provenance: <http://art-auction.io/ontology/provenance#> .

@prefix mv:   <http://art-auction.io/data/movement/> .
@prefix pr:   <http://art-auction.io/data/period/> .
@prefix ar:   <http://art-auction.io/data/artist/> .
@prefix aw:   <http://art-auction.io/data/artwork/> .
@prefix cp:   <http://art-auction.io/data/palette/> .
@prefix lot:  <http://art-auction.io/data/lot/> .
@prefix prov: <http://art-auction.io/data/provenance/> .

# ─────────────────────────────────────────────
# 미술 사조 (ArtMovement)
# ─────────────────────────────────────────────

mv:impressionism a artwork:ArtMovement ;
    rdfs:label       "인상주의"@ko , "Impressionism"@en ;
    artwork:name     "인상주의" ;
    artwork:movementEra "modern" .

mv:korean-abstract a artwork:ArtMovement ;
    rdfs:label       "한국 추상표현주의"@ko , "Korean Abstract Expressionism"@en ;
    artwork:name     "한국 추상표현주의" ;
    artwork:movementEra "modern" .

mv:korean-realism a artwork:ArtMovement ;
    rdfs:label       "한국 민족 리얼리즘"@ko , "Korean Nationalist Realism"@en ;
    artwork:name     "한국 민족 리얼리즘" ;
    artwork:movementEra "modern" .

mv:korean-figurative a artwork:ArtMovement ;
    rdfs:label       "한국 서정적 구상"@ko , "Korean Lyrical Figurative"@en ;
    artwork:name     "한국 서정적 구상" ;
    artwork:movementEra "modern" .

# ─────────────────────────────────────────────
# 시대 (Period)
# ─────────────────────────────────────────────

pr:1880s a artwork:Period ;
    rdfs:label    "1880년대"@ko ;
    artwork:decade "1880s" ;
    artwork:era    "modern" .

pr:1900s a artwork:Period ;
    rdfs:label    "1900년대"@ko ;
    artwork:decade "1900s" ;
    artwork:era    "modern" .

pr:1920s a artwork:Period ;
    rdfs:label    "1920년대"@ko ;
    artwork:decade "1920s" ;
    artwork:era    "modern" .

pr:1930s a artwork:Period ;
    rdfs:label    "1930년대"@ko ;
    artwork:decade "1930s" ;
    artwork:era    "modern" .

pr:1950s a artwork:Period ;
    rdfs:label    "1950년대"@ko ;
    artwork:decade "1950s" ;
    artwork:era    "modern" .

pr:1960s a artwork:Period ;
    rdfs:label    "1960년대"@ko ;
    artwork:decade "1960s" ;
    artwork:era    "modern" .

pr:1970s a artwork:Period ;
    rdfs:label    "1970년대"@ko ;
    artwork:decade "1970s" ;
    artwork:era    "modern" .

pr:1980s a artwork:Period ;
    rdfs:label    "1980년대"@ko ;
    artwork:decade "1980s" ;
    artwork:era    "modern" .

# ─────────────────────────────────────────────
# 색감 팔레트 (ColorPalette)
# ─────────────────────────────────────────────

cp:warm-high-high a artwork:ColorPalette ;
    rdfs:label         "따뜻한 고채도 고명도"@ko ;
    artwork:temperature "warm" ;
    artwork:saturation  "high" ;
    artwork:brightness  "high" ;
    artwork:dominantColor "yellow-green, violet" .

cp:warm-medium-high a artwork:ColorPalette ;
    rdfs:label         "따뜻한 중채도 고명도"@ko ;
    artwork:temperature "warm" ;
    artwork:saturation  "medium" ;
    artwork:brightness  "high" ;
    artwork:dominantColor "gold, orange" .

cp:warm-high-medium a artwork:ColorPalette ;
    rdfs:label         "따뜻한 고채도 중명도"@ko ;
    artwork:temperature "warm" ;
    artwork:saturation  "high" ;
    artwork:brightness  "medium" ;
    artwork:dominantColor "red, orange" .

cp:warm-high-low a artwork:ColorPalette ;
    rdfs:label         "따뜻한 고채도 저명도"@ko ;
    artwork:temperature "warm" ;
    artwork:saturation  "high" ;
    artwork:brightness  "low" ;
    artwork:dominantColor "dark red, brown" .

cp:cool-high-medium a artwork:ColorPalette ;
    rdfs:label         "차가운 고채도 중명도"@ko ;
    artwork:temperature "cool" ;
    artwork:saturation  "high" ;
    artwork:brightness  "medium" ;
    artwork:dominantColor "blue, indigo" .

cp:cool-medium-medium a artwork:ColorPalette ;
    rdfs:label         "차가운 중채도 중명도"@ko ;
    artwork:temperature "cool" ;
    artwork:saturation  "medium" ;
    artwork:brightness  "medium" ;
    artwork:dominantColor "blue-grey, silver" .

cp:neutral-low-medium a artwork:ColorPalette ;
    rdfs:label         "중성 저채도 중명도"@ko ;
    artwork:temperature "neutral" ;
    artwork:saturation  "low" ;
    artwork:brightness  "medium" ;
    artwork:dominantColor "grey, beige" .

cp:neutral-medium-medium a artwork:ColorPalette ;
    rdfs:label         "중성 중채도 중명도"@ko ;
    artwork:temperature "neutral" ;
    artwork:saturation  "medium" ;
    artwork:brightness  "medium" ;
    artwork:dominantColor "ochre, earth tone" .

# ─────────────────────────────────────────────
# 작가 (Artist)
# ─────────────────────────────────────────────

ar:monet-claude a artwork:Artist ;
    rdfs:label         "클로드 모네"@ko , "Claude Monet"@en ;
    artwork:birthYear  1840 ;
    artwork:deathYear  1926 ;
    artwork:nationality "French" ;
    artwork:memberOf   mv:impressionism .

ar:kim-whanki a artwork:Artist ;
    rdfs:label         "김환기"@ko , "Kim Whanki"@en ;
    artwork:birthYear  1913 ;
    artwork:deathYear  1974 ;
    artwork:nationality "Korean" ;
    artwork:memberOf   mv:korean-abstract .

ar:park-sookeun a artwork:Artist ;
    rdfs:label         "박수근"@ko , "Park Soo-keun"@en ;
    artwork:birthYear  1914 ;
    artwork:deathYear  1965 ;
    artwork:nationality "Korean" ;
    artwork:memberOf   mv:korean-realism .

ar:lee-jungseop a artwork:Artist ;
    rdfs:label         "이중섭"@ko , "Lee Jung-seop"@en ;
    artwork:birthYear  1916 ;
    artwork:deathYear  1956 ;
    artwork:nationality "Korean" ;
    artwork:memberOf   mv:korean-realism .

ar:chun-kyungja a artwork:Artist ;
    rdfs:label         "천경자"@ko , "Chun Kyung-ja"@en ;
    artwork:birthYear  1924 ;
    artwork:deathYear  2015 ;
    artwork:nationality "Korean" ;
    artwork:memberOf   mv:korean-figurative .

